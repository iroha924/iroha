{
  "name": "@iroha/forge-github",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "iroha — GitHub forge implementation",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --dts",
    "codegen": "graphql-codegen --config codegen.ts",
    "lint": "biome check src",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@graphql-typed-document-node/core": "catalog:",
    "@iroha/forge": "workspace:*",
    "@octokit/core": "catalog:",
    "@octokit/plugin-paginate-graphql": "catalog:",
    "@octokit/plugin-retry": "catalog:",
    "@octokit/plugin-throttling": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@graphql-codegen/cli": "catalog:",
    "@graphql-codegen/typed-document-node": "catalog:",
    "@graphql-codegen/typescript": "catalog:",
    "@graphql-codegen/typescript-operations": "catalog:",
    "@octokit/graphql-schema": "catalog:",
    "@types/node": "catalog:",
    "graphql": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
