{
  "name": "@iroha/adapter-claude",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "iroha — Claude Code input/output mapping",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --dts",
    "lint": "biome check src",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@iroha/platform": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
