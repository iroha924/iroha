{
  "name": "@iroha/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "iroha — application use cases and transactions",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --dts",
    "lint": "biome check src",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@iroha/domain": "workspace:*",
    "@iroha/config": "workspace:*",
    "@iroha/canonical": "workspace:*",
    "@iroha/storage": "workspace:*",
    "@iroha/search": "workspace:*",
    "@iroha/git": "workspace:*",
    "@iroha/forge": "workspace:*",
    "@iroha/forge-github": "workspace:*",
    "@iroha/platform": "workspace:*",
    "@iroha/adapter-claude": "workspace:*",
    "@iroha/adapter-codex": "workspace:*",
    "picomatch": "catalog:",
    "yaml": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/node": "catalog:",
    "@types/picomatch": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
