{
  "name": "@iroha/plugin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "iroha — manifests, hooks, skills, packaged dist",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iroha924/iroha.git"
  },
  "homepage": "https://github.com/iroha924/iroha",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "bin": {
    "iroha": "./dist/bin.mjs"
  },
  "files": [
    "dist",
    "skills"
  ],
  "scripts": {
    "build": "tsdown",
    "build:archive": "node dist/build-archive-cli.mjs",
    "build:release": "node dist/build-release-cli.mjs",
    "lint": "biome check src",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests --exclude \"**/archive-smoke.test.ts\" --exclude \"**/release-pack.test.ts\"",
    "test:package": "vitest run archive-smoke release-pack"
  },
  "dependencies": {
    "@hono/node-server": "catalog:",
    "@iroha/cli": "workspace:*",
    "@iroha/mcp": "workspace:*",
    "@libsql/client": "catalog:",
    "@modelcontextprotocol/sdk": "catalog:",
    "@secretlint/node": "catalog:",
    "@secretlint/secretlint-rule-pattern": "catalog:",
    "@secretlint/secretlint-rule-preset-recommend": "catalog:",
    "gunshi": "catalog:",
    "hono": "catalog:",
    "mdast-util-from-markdown": "catalog:",
    "mdast-util-to-string": "catalog:",
    "picomatch": "catalog:",
    "secretlint": "catalog:",
    "unist-util-visit": "catalog:",
    "yaml": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
