{
  "name": "@iroha/canonical",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "iroha — Markdown/frontmatter parse, validate, publish",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --dts",
    "lint": "biome check src",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@iroha/domain": "workspace:*",
    "@iroha/config": "workspace:*",
    "@secretlint/node": "catalog:",
    "@secretlint/secretlint-rule-preset-recommend": "catalog:",
    "mdast-util-from-markdown": "catalog:",
    "mdast-util-to-string": "catalog:",
    "secretlint": "catalog:",
    "unist-util-visit": "catalog:",
    "yaml": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
