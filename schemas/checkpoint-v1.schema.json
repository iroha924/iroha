{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://iroha-labs.com/schemas/checkpoint-v1.schema.json",
  "title": "iroha create_checkpoint input v1",
  "type": "object",
  "required": [
    "schemaVersion",
    "sessionToken",
    "idempotencyKey",
    "outcome",
    "objective",
    "summary",
    "implementation",
    "validation",
    "unresolved",
    "references",
    "labels",
    "proposals"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "sessionToken": {
      "type": "string",
      "pattern": "^ist_[A-Za-z0-9_-]{43}$"
    },
    "idempotencyKey": {
      "type": "string",
      "minLength": 16,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "turnId": {
      "type": "string",
      "pattern": "^trn_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "outcome": {
      "enum": ["completed", "partial", "blocked", "no_change"]
    },
    "objective": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 5000
    },
    "implementation": {
      "type": "array",
      "maxItems": 200,
      "items": { "$ref": "#/$defs/implementationItem" }
    },
    "validation": {
      "type": "array",
      "maxItems": 100,
      "items": { "$ref": "#/$defs/validationItem" }
    },
    "unresolved": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1000
      }
    },
    "references": {
      "type": "array",
      "maxItems": 100,
      "items": { "$ref": "#/$defs/reference" }
    },
    "labels": {
      "type": "array",
      "maxItems": 50,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
        "maxLength": 64
      },
      "uniqueItems": true
    },
    "proposals": {
      "type": "array",
      "maxItems": 50,
      "items": { "$ref": "#/$defs/proposal" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500,
      "not": { "pattern": "^(?:/|[A-Za-z]:|.*(?:^|/)\\.\\.(?:/|$))" }
    },
    "implementationItem": {
      "type": "object",
      "required": ["change"],
      "properties": {
        "file": { "$ref": "#/$defs/relativePath" },
        "symbol": { "type": "string", "maxLength": 500 },
        "change": { "type": "string", "minLength": 1, "maxLength": 2000 }
      },
      "anyOf": [
        { "properties": { "file": true }, "required": ["file"] },
        { "properties": { "symbol": true }, "required": ["symbol"] }
      ],
      "additionalProperties": false
    },
    "validationItem": {
      "type": "object",
      "required": ["result"],
      "properties": {
        "command": { "type": "string", "maxLength": 2000 },
        "result": { "enum": ["passed", "failed", "not_run"] },
        "note": { "type": "string", "maxLength": 2000 },
        "durationMs": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "reference": {
      "type": "object",
      "required": ["type", "ref"],
      "properties": {
        "type": {
          "enum": ["issue", "pull_request", "review", "commit", "file", "symbol", "url", "document"]
        },
        "ref": { "type": "string", "minLength": 1, "maxLength": 500 },
        "url": { "type": "string", "format": "uri", "maxLength": 2048 },
        "path": { "$ref": "#/$defs/relativePath" }
      },
      "additionalProperties": false
    },
    "scope": {
      "type": "object",
      "required": ["paths", "symbols"],
      "properties": {
        "paths": {
          "type": "array",
          "maxItems": 100,
          "items": { "$ref": "#/$defs/relativePath" },
          "uniqueItems": true
        },
        "symbols": {
          "type": "array",
          "maxItems": 100,
          "items": { "type": "string", "maxLength": 500 },
          "uniqueItems": true
        },
        "languages": {
          "type": "array",
          "maxItems": 20,
          "items": { "type": "string", "pattern": "^[a-z0-9+#.-]{1,32}$" },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "guard": {
      "type": "object",
      "required": ["tools", "paths"],
      "properties": {
        "tools": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "maxLength": 100 },
          "uniqueItems": true
        },
        "paths": {
          "type": "array",
          "items": { "$ref": "#/$defs/relativePath" },
          "uniqueItems": true
        },
        "denyCommands": {
          "type": "array",
          "items": { "type": "string", "maxLength": 500 },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "proposal": {
      "type": "object",
      "required": ["type", "title", "summary", "body", "labels", "scope", "sources"],
      "properties": {
        "type": {
          "enum": ["decision", "rule", "concept", "insight", "incident", "pattern", "review_learning"]
        },
        "title": { "type": "string", "minLength": 1, "maxLength": 160 },
        "summary": { "type": "string", "minLength": 1, "maxLength": 1000 },
        "body": { "type": "string", "minLength": 1, "maxLength": 20000 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "labels": {
          "type": "array",
          "maxItems": 50,
          "items": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "uniqueItems": true
        },
        "scope": { "$ref": "#/$defs/scope" },
        "enforcement": { "enum": ["advisory", "guardrail"] },
        "guard": { "$ref": "#/$defs/guard" },
        "sources": {
          "type": "array",
          "minItems": 1,
          "maxItems": 100,
          "items": { "$ref": "#/$defs/reference" }
        },
        "relations": {
          "type": "array",
          "maxItems": 100,
          "items": {
            "type": "object",
            "required": ["type", "target"],
            "properties": {
              "type": { "type": "string", "maxLength": 50 },
              "target": { "type": "string", "maxLength": 64 }
            },
            "additionalProperties": false
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "enforcement": { "const": "guardrail" } },
            "required": ["enforcement"]
          },
          "then": { "properties": { "guard": true }, "required": ["guard"] }
        }
      ],
      "additionalProperties": false
    }
  }
}
