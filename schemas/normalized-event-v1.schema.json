{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://iroha-labs.com/schemas/normalized-event-v1.schema.json",
  "title": "iroha normalized hook event v1",
  "type": "object",
  "required": [
    "schemaVersion",
    "eventId",
    "platform",
    "kind",
    "occurredAt",
    "platformSessionId",
    "cwdFingerprint",
    "payload"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "eventId": { "type": "string", "pattern": "^evt_[0-9A-HJKMNP-TV-Z]{26}$" },
    "platform": { "enum": ["claude_code", "codex"] },
    "kind": {
      "enum": [
        "SESSION_STARTED",
        "PROMPT_SUBMITTED",
        "TOOL_STARTED",
        "TOOL_COMPLETED",
        "TOOL_FAILED",
        "PERMISSION_REQUESTED",
        "COMPACTION_STARTED",
        "COMPACTION_COMPLETED",
        "AGENT_STARTED",
        "AGENT_STOPPED",
        "TURN_STOPPED",
        "TURN_FAILED",
        "SESSION_ENDED",
        "INSTRUCTIONS_OBSERVED",
        "TASK_CREATED",
        "TASK_COMPLETED"
      ]
    },
    "occurredAt": { "type": "string", "format": "date-time", "pattern": "Z$" },
    "platformSessionId": { "type": "string", "minLength": 1, "maxLength": 500 },
    "platformTurnId": { "type": "string", "maxLength": 500 },
    "cwdFingerprint": { "type": "string", "pattern": "^hmac-sha256:[a-f0-9]{64}$" },
    "model": { "type": "string", "maxLength": 200 },
    "permissionMode": { "type": "string", "maxLength": 100 },
    "payload": { "$ref": "#/$defs/payload" }
  },
  "allOf": [
    {
      "if": { "properties": { "kind": { "const": "SESSION_STARTED" } }, "required": ["kind"] },
      "then": { "properties": { "payload": { "type": "object", "properties": { "source": true }, "required": ["source"] } } }
    },
    {
      "if": { "properties": { "kind": { "const": "PROMPT_SUBMITTED" } }, "required": ["kind"] },
      "then": { "properties": { "payload": { "type": "object", "properties": { "promptDigest": true }, "required": ["promptDigest"] } } }
    },
    {
      "if": { "properties": { "kind": { "const": "TOOL_STARTED" } }, "required": ["kind"] },
      "then": { "properties": { "payload": { "type": "object", "properties": { "toolName": true, "phase": { "const": "pre" }, "targets": true, "status": { "const": "started" } }, "required": ["toolName", "phase", "targets", "status"] } } }
    },
    {
      "if": { "properties": { "kind": { "const": "TOOL_COMPLETED" } }, "required": ["kind"] },
      "then": { "properties": { "payload": { "type": "object", "properties": { "toolName": true, "phase": { "const": "post" }, "targets": true, "status": { "const": "succeeded" } }, "required": ["toolName", "phase", "targets", "status"] } } }
    },
    {
      "if": { "properties": { "kind": { "const": "TOOL_FAILED" } }, "required": ["kind"] },
      "then": { "properties": { "payload": { "type": "object", "properties": { "toolName": true, "phase": { "const": "failure" }, "targets": true, "status": { "const": "failed" } }, "required": ["toolName", "phase", "targets", "status"] } } }
    },
    {
      "if": { "properties": { "kind": { "const": "PERMISSION_REQUESTED" } }, "required": ["kind"] },
      "then": { "properties": { "payload": { "type": "object", "properties": { "toolName": true, "phase": { "const": "permission" }, "targets": true, "status": { "const": "requested" } }, "required": ["toolName", "phase", "targets", "status"] } } }
    },
    {
      "if": { "properties": { "kind": { "enum": ["COMPACTION_STARTED", "COMPACTION_COMPLETED"] } }, "required": ["kind"] },
      "then": { "properties": { "payload": { "type": "object", "properties": { "trigger": true }, "required": ["trigger"] } } }
    },
    {
      "if": { "properties": { "kind": { "const": "AGENT_STARTED" } }, "required": ["kind"] },
      "then": { "properties": { "payload": { "type": "object", "properties": { "agentId": true, "agentType": true, "phase": { "const": "start" } }, "required": ["agentId", "agentType", "phase"] } } }
    },
    {
      "if": { "properties": { "kind": { "const": "AGENT_STOPPED" } }, "required": ["kind"] },
      "then": { "properties": { "payload": { "type": "object", "properties": { "agentId": true, "agentType": true, "phase": { "const": "stop" } }, "required": ["agentId", "agentType", "phase"] } } }
    },
    {
      "if": { "properties": { "kind": { "const": "TURN_STOPPED" } }, "required": ["kind"] },
      "then": { "properties": { "payload": { "type": "object", "properties": { "stopHookActive": true, "backgroundTaskCount": true }, "required": ["stopHookActive", "backgroundTaskCount"] } } }
    },
    {
      "if": { "properties": { "kind": { "enum": ["TURN_FAILED", "SESSION_ENDED"] } }, "required": ["kind"] },
      "then": { "properties": { "payload": { "type": "object", "properties": { "reason": true }, "required": ["reason"] } } }
    },
    {
      "if": { "properties": { "kind": { "const": "INSTRUCTIONS_OBSERVED" } }, "required": ["kind"] },
      "then": { "properties": { "payload": { "type": "object", "properties": { "sourcePath": true, "loadReason": true }, "required": ["sourcePath", "loadReason"] } } }
    },
    {
      "if": { "properties": { "kind": { "const": "TASK_CREATED" } }, "required": ["kind"] },
      "then": { "properties": { "payload": { "type": "object", "properties": { "taskId": true, "subject": true, "phase": { "const": "created" } }, "required": ["taskId", "subject", "phase"] } } }
    },
    {
      "if": { "properties": { "kind": { "const": "TASK_COMPLETED" } }, "required": ["kind"] },
      "then": { "properties": { "payload": { "type": "object", "properties": { "taskId": true, "subject": true, "phase": { "const": "completed" } }, "required": ["taskId", "subject", "phase"] } } }
    }
  ],
  "additionalProperties": false,
  "$defs": {
    "digest": { "type": "string", "pattern": "^hmac-sha256:[a-f0-9]{64}$" },
    "target": {
      "type": "object",
      "required": ["kind", "value"],
      "properties": {
        "kind": { "enum": ["file", "path", "command", "mcp", "other"] },
        "value": { "type": "string", "minLength": 1, "maxLength": 500 },
        "operation": { "enum": ["read", "write", "delete", "execute", "unknown"] }
      },
      "additionalProperties": false
    },
    "payload": {
      "oneOf": [
        {
          "type": "object",
          "required": ["source"],
          "properties": { "source": { "enum": ["startup", "resume", "clear", "compact"] } },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["promptDigest"],
          "properties": { "promptDigest": { "$ref": "#/$defs/digest" } },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["toolName", "phase", "targets", "status"],
          "properties": {
            "toolName": { "type": "string", "minLength": 1, "maxLength": 200 },
            "toolUseId": { "type": "string", "maxLength": 500 },
            "phase": { "enum": ["pre", "post", "failure", "permission"] },
            "targets": { "type": "array", "maxItems": 100, "items": { "$ref": "#/$defs/target" } },
            "inputDigest": { "$ref": "#/$defs/digest" },
            "responseDigest": { "$ref": "#/$defs/digest" },
            "status": { "enum": ["started", "succeeded", "failed", "denied", "requested"] },
            "durationMs": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["trigger"],
          "properties": {
            "trigger": { "enum": ["manual", "auto"] },
            "summaryDigest": { "$ref": "#/$defs/digest" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["agentId", "agentType", "phase"],
          "properties": {
            "agentId": { "type": "string", "minLength": 1, "maxLength": 500 },
            "agentType": { "type": "string", "minLength": 1, "maxLength": 200 },
            "phase": { "enum": ["start", "stop"] },
            "stopHookActive": { "type": "boolean" },
            "lastMessageDigest": { "$ref": "#/$defs/digest" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["stopHookActive", "backgroundTaskCount"],
          "properties": {
            "stopHookActive": { "type": "boolean" },
            "backgroundTaskCount": { "type": "integer", "minimum": 0 },
            "lastMessageDigest": { "$ref": "#/$defs/digest" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["reason"],
          "properties": { "reason": { "type": "string", "minLength": 1, "maxLength": 200 } },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["sourcePath", "loadReason"],
          "properties": {
            "sourcePath": { "type": "string", "minLength": 1, "maxLength": 500 },
            "loadReason": { "type": "string", "minLength": 1, "maxLength": 200 }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["taskId", "subject", "phase"],
          "properties": {
            "taskId": { "type": "string", "minLength": 1, "maxLength": 500 },
            "subject": { "type": "string", "minLength": 1, "maxLength": 500 },
            "phase": { "enum": ["created", "completed"] }
          },
          "additionalProperties": false
        }
      ]
    }
  }
}
