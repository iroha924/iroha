{
  "name": "iroha",
  "private": true,
  "packageManager": "pnpm@11.14.0",
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "scripts": {
    "prepare": "lefthook install",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:contracts": "turbo run test:contracts",
    "test:integration": "turbo run test:integration",
    "test:e2e": "turbo run test:e2e",
    "test:package": "turbo run test:package",
    "format": "biome format --write .",
    "changeset": "changeset",
    "dashboard": "pnpm build && node packages/cli/dist/bin.mjs dashboard",
    "dashboard:api": "pnpm build && IROHA_DASHBOARD_DEV_TOKEN=iroha-dev node packages/cli/dist/bin.mjs dashboard --port 5178 --no-open",
    "dashboard:web": "pnpm --filter @iroha/dashboard dev",
    "link:global": "pnpm build && cd packages/cli && pnpm link --global"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@changesets/cli": "catalog:",
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "lefthook": "catalog:",
    "turbo": "2.10.5"
  }
}
