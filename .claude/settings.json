{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git push *)",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/check-path-safety-diff.sh",
            "timeout": 15,
            "statusMessage": "Checking for new path.resolve()/path.join() calls in path-safety-critical files..."
          }
        ]
      }
    ]
  }
}
